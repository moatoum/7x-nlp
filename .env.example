# Azure AI Foundry
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_KEY=your-api-key
AZURE_AI_DEPLOYMENT=your-deployment-name
AZURE_AI_API_VERSION=2025-01-01-preview

# Azure PostgreSQL
DATABASE_URL=postgresql://user:password@server.postgres.database.azure.com:5432/dbname?schema=main&sslmode=require

# Email
RESEND_API_KEY=re_your-key

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-password
